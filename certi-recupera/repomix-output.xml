  }

  .mobile-header-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;

    .mobile-logo {
      width: 1.75rem;
      height: 1.75rem;
    }

    .mobile-app-title {
      font-size: 1.125rem;
      font-weight: 700;
      font-family: 'Outfit', sans-serif;
      color: var(--text-primary);
    }
