<file path="src/styles/_mixins.scss">
// Sass Mixins for layout, responsiveness, and animations
@use 'variables' as *;

// Flexbox utilities
@mixin flex($direction: row, $justify: start, $align: stretch, $wrap: nowrap) {
  display: flex;
  flex-direction: $direction;
  justify-content: $justify;
  align-items: $align;
  flex-wrap: $wrap;
}

@mixin flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

@mixin flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

@mixin flex-column {
  display: flex;
  flex-direction: column;
}

// Media Queries based on breakpoints
@mixin xs {
  @media (max-width: #{$breakpoint-xs}) { @content; }
}

@mixin sm {
  @media (min-width: #{$breakpoint-sm}) { @content; }
}

@mixin md {
  @media (min-width: #{$breakpoint-md}) { @content; }
}

@mixin lg {
  @media (min-width: #{$breakpoint-lg}) { @content; }
}

@mixin xl {
  @media (min-width: #{$breakpoint-xl}) { @content; }
}

// Glassmorphism effect
@mixin glass-panel {
  background: var(--glass-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid var(--glass-border);
  box-shadow: var(--card-shadow);
}

// Custom Scrollbar
@mixin custom-scroll {
  &::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  &::-webkit-scrollbar-track {
    background: transparent;
  }
  &::-webkit-scrollbar-thumb {
    background: var(--border-color);
    border-radius: $radius-full;
    &:hover {
      background: var(--text-tertiary);
    }
  }
}

// Micro-animations
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeOut {
  from {
    opacity: 1;
    transform: translateY(0);
  }
  to {
    opacity: 0;
    transform: translateY(10px);
  }
}

@keyframes pulse-glow {
  0%, 100% {
    box-shadow: 0 0 5px rgba(99, 102, 241, 0.2);
  }
  50% {
    box-shadow: 0 0 15px rgba(99, 102, 241, 0.6);
  }
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

@mixin animate-fade-in($duration: 0.3s, $delay: 0s) {
  animation: fadeIn $duration cubic-bezier(0.4, 0, 0.2, 1) $delay both;
}

@mixin hover-lift {
  transition: $transition-normal;
  &:hover {
    transform: translateY(-4px);
    box-shadow: var(--card-shadow), 0 12px 20px -8px rgba(0, 0, 0, 0.15);
  }
  &:active {
    transform: translateY(-1px);
  }
}

@mixin click-scale {
  transition: $transition-fast;
  &:active {
    transform: scale(0.96);
  }
}
